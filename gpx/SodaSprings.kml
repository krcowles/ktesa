    <Folder id="Waypoints">
      <name>Waypoints</name>
      <visibility>1</visibility>
      <Placemark>
        <name>Fork: We turned south here. Might be better to turn north and follow Trail 306 more closely.</name>
        <Snippet></Snippet>
        <description><![CDATA[&nbsp;]]></description>
        <styleUrl>#gv_waypoint</styleUrl>
        <Style>
          <IconStyle>
            <scale>0.5</scale>
            <Icon>
              <href>http://maps.gpsvisualizer.com/google_maps/icons/garmin/gpsmap/Flag%2C_Red.png</href>
            </Icon>
          </IconStyle>
        </Style>
        <Point>
          <altitudeMode>clampToGround</altitudeMode>
          <coordinates>-106.170268022,35.809766036,1822.168</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Trailhead: Start of ascent to Sagebrush Flats. This is marked with a trailhead sign, so it seems to be the official turning point, even though Trail 306 on the topo map turns uphill farther north.</name>
        <Snippet></Snippet>
        <description><![CDATA[&nbsp;]]></description>
        <styleUrl>#gv_waypoint</styleUrl>
